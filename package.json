{
  "name": "whisper-cpp-capacitor",
  "version": "0.1.0",
  "description": "Native Capacitor plugin embedding whisper.cpp for offline speech-to-text on iOS, Android, and Web.",
  "main": "dist/plugin.cjs.js",
  "type": "module",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "build-native.sh",
    "cpp/",
    "dist/",
    "ios/CMakeLists.txt",
    "ios/Sources",
    "ios/Frameworks",
    "Package.swift",
    "WhisperCpp.podspec",
    "types/"
  ],
  "author": "",
  "license": "MIT",
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "ios",
    "android",
    "whisper",
    "whisper.cpp",
    "speech-to-text",
    "stt",
    "transcription",
    "offline"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "build:native": "./build-native.sh",
    "build:all": "npm run build && npm run build:native",
    "clean": "rimraf ./dist",
    "clean:native": "rimraf ios/build ios/Frameworks android/build android/src/main/jniLibs",
    "lint": "eslint . --ext ts",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --testPathIgnorePatterns=test/integration",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
